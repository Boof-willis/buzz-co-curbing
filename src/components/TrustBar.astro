---
// TrustBar — horizontal strip of trust badges below hero
// Mobile uses infinite marquee, Desktop uses centered flex wrap
---

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee {
    animation: marquee 20s linear infinite;
  }
  .pause-on-hover:hover {
    animation-play-state: paused;
  }
</style>

<section
  class="relative overflow-hidden bg-warm-white py-5 md:py-8 border-b border-dark/5"
  aria-label="Trust badges"
>
  <!-- Desktop Layout -->
  <div class="hidden md:flex flex-wrap items-center justify-center gap-8 px-6 w-full max-w-7xl mx-auto">
    <!-- Licensed & Insured -->
    <div class="flex items-center gap-3 border-r border-dark/10 pr-8">
      <svg class="h-5 w-5 shrink-0 text-dark/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
      </svg>
      <span class="font-data text-xs uppercase tracking-wider text-dark/50">Licensed & Insured</span>
    </div>
    <!-- 4.9★ Google Rating -->
    <div class="flex items-center gap-3 border-r border-dark/10 pr-8">
      <svg class="h-5 w-5 shrink-0 text-dark/50" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
      </svg>
      <span class="font-data text-xs uppercase tracking-wider text-dark/50">4.9★ Google Rating</span>
    </div>
    <!-- 15+ Years in Business -->
    <div class="flex items-center gap-3 border-r border-dark/10 pr-8">
      <svg class="h-5 w-5 shrink-0 text-dark/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
      </svg>
      <span class="font-data text-xs uppercase tracking-wider text-dark/50">15+ Years in Business</span>
    </div>
    <!-- Same-Week Scheduling -->
    <div class="flex items-center gap-3">
      <svg class="h-5 w-5 shrink-0 text-dark/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <span class="font-data text-xs uppercase tracking-wider text-dark/50">Same-Week Scheduling</span>
    </div>
  </div>

  <!-- Mobile Layout (Marquee) -->
  <div class="flex md:hidden w-max animate-marquee pause-on-hover items-center">
    {/* First Set */}
    <div class="flex items-center gap-8 pr-8">
      <div class="flex items-center gap-2">
        <svg class="h-4 w-4 shrink-0 text-dark/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
        <span class="font-data text-[11px] uppercase tracking-wider text-dark/60 whitespace-nowrap">Licensed & Insured</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="h-4 w-4 shrink-0 text-dark/40" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" /></svg>
        <span class="font-data text-[11px] uppercase tracking-wider text-dark/60 whitespace-nowrap">4.9★ Google Rating</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="h-4 w-4 shrink-0 text-dark/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
        <span class="font-data text-[11px] uppercase tracking-wider text-dark/60 whitespace-nowrap">15+ Years in Business</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="h-4 w-4 shrink-0 text-dark/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <span class="font-data text-[11px] uppercase tracking-wider text-dark/60 whitespace-nowrap">Same-Week Scheduling</span>
      </div>
    </div>
    {/* Duplicate Set for Infinite Loop */}
    <div class="flex items-center gap-8 pr-8" aria-hidden="true">
      <div class="flex items-center gap-2">
        <svg class="h-4 w-4 shrink-0 text-dark/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
        <span class="font-data text-[11px] uppercase tracking-wider text-dark/60 whitespace-nowrap">Licensed & Insured</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="h-4 w-4 shrink-0 text-dark/40" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" /></svg>
        <span class="font-data text-[11px] uppercase tracking-wider text-dark/60 whitespace-nowrap">4.9★ Google Rating</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="h-4 w-4 shrink-0 text-dark/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
        <span class="font-data text-[11px] uppercase tracking-wider text-dark/60 whitespace-nowrap">15+ Years in Business</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="h-4 w-4 shrink-0 text-dark/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <span class="font-data text-[11px] uppercase tracking-wider text-dark/60 whitespace-nowrap">Same-Week Scheduling</span>
      </div>
    </div>
  </div>
</section>
