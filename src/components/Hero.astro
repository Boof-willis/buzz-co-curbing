---
interface Props {
  locationId: string;
  locationName: string;
  cityName: string;
  stateName?: string;
  headline?: string;
  phone: string;
  phoneHref: string;
  estimateUrl: string;
}

const { locationId, locationName, cityName, stateName = 'Utah', headline, phone, phoneHref, estimateUrl } = Astro.props;
---

<section
  id="hero-section"
  class="relative flex min-h-[100dvh] items-end overflow-hidden pb-16 md:pb-28"
  aria-label="Hero"
>
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src="/images/og-image.jpg"
      alt={`Decorative concrete curbing in ${cityName} — clean stamped edges along green lawn with mountain backdrop`}
      class="h-full w-full object-cover"
      loading="eager"
      fetchpriority="high"
      width="1920"
      height="1080"
    />
  </div>
  <!-- Gradient overlays -->
  <div class="absolute inset-0 bg-gradient-to-r from-[#1a1a1a]/95 via-[#1a1a1a]/50 to-transparent"></div>
  <div class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-[#1a1a1a]/90 to-transparent"></div>

  <!-- Content -->
  <div class="relative z-10 mx-auto w-full max-w-7xl px-6 md:px-8 flex flex-col justify-end">
    <p
      data-hero-animate
      class="mb-4 block font-data text-xs md:text-sm uppercase tracking-widest text-white/60"
    >
      EST. 2010 — CACHE VALLEY TO UTAH COUNTY
    </p>
    <h1
      data-hero-animate
      class="mb-6 block max-w-4xl font-drama text-5xl leading-[1.05] tracking-tight text-white md:text-7xl lg:text-[5rem]"
    >
      {headline ?? `Crafted Concrete Curbing Across ${cityName}.`}
    </h1>

    <p
      data-hero-animate
      class="mb-10 max-w-2xl font-body text-base font-medium text-white/80 md:text-lg"
    >
      Custom colors, stamped patterns, and same-week installation for homeowners along the Wasatch Front. Local crews in Cache Valley, Weber, Davis, Salt Lake, and Utah counties.
    </p>

    <!-- CTA row -->
    <div data-hero-animate class="flex flex-wrap items-center gap-6 pb-6">
      <a href="#get-started" class="btn-primary" data-estimate-href>
        Get a Free Estimate
      </a>
      <div class="flex items-center gap-6">
        <span class="font-body text-lg text-white/50">or</span>
        <a
          href={phoneHref}
          data-phone-href
          class="font-data text-xl font-medium text-white/90 transition-colors hover:text-white"
        >
          Call <span data-phone-display>{phone}</span>
        </a>
      </div>
    </div>

    <!-- Trust stats -->
    <div
      data-hero-animate
      class="flex flex-row items-center font-data text-sm text-white/70"
    >
      <div class="flex items-center">
        <div class="flex mr-2 text-[#fcc33c]" aria-hidden="true">
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        </div>
        <span>4.9 Google Rating</span>
      </div>
      <div class="border-l border-white/20 pl-6 ml-6">
        <span>15+ Years</span>
      </div>
      <div class="border-l border-white/20 pl-6 ml-6">
        <span>1,000+ Projects</span>
      </div>
    </div>
  </div>
</section>
