---
/**
 * NoiseOverlay.astro
 * Pure CSS noise overlay using inline SVG feTurbulence filter.
 * Eliminates flat digital gradients. Zero JS.
 */
---

<div
  class="pointer-events-none fixed inset-0 z-[1] opacity-[0.05]"
  aria-hidden="true"
>
  <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
    <filter id="noise">
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.65"
        numOctaves="3"
        stitchTiles="stitch"
      />
    </filter>
    <rect width="100%" height="100%" filter="url(#noise)" />
  </svg>
</div>
