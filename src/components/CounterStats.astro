---
// Static counter stats — React island (CounterStatsAnimation.jsx) animates from 0 on desktop
// Final values displayed by default for SEO and no-JS fallback
---

<section class="bg-warm-white py-16 md:py-24" aria-label="Statistics">
  <div class="mx-auto max-w-5xl px-6 md:px-8">
    <div class="grid grid-cols-2 gap-8 text-center md:grid-cols-4 md:gap-12">
      <div>
        <span
          class="counter-number font-heading text-4xl font-bold text-dark md:text-6xl"
          data-count-target="15"
          data-count-suffix="+"
        >
          15+
        </span>
        <p class="font-data mt-2 text-xs uppercase tracking-widest text-warm-muted">Years in Business</p>
      </div>
      <div>
        <span
          class="counter-number font-heading text-4xl font-bold text-dark md:text-6xl"
          data-count-target="2000"
          data-count-suffix="+"
        >
          2,000+
        </span>
        <p class="font-data mt-2 text-xs uppercase tracking-widest text-warm-muted">Yards Transformed</p>
      </div>
      <div>
        <span
          class="counter-number font-heading text-4xl font-bold text-dark md:text-6xl"
          data-count-target="4.9"
          data-count-suffix="★"
        >
          4.9★
        </span>
        <p class="font-data mt-2 text-xs uppercase tracking-widest text-warm-muted">Google Rating</p>
      </div>
      <div>
        <span
          class="counter-number font-heading text-4xl font-bold text-dark md:text-6xl"
          data-count-target="1"
          data-count-suffix="-Day"
        >
          1-Day
        </span>
        <p class="font-data mt-2 text-xs uppercase tracking-widest text-warm-muted">Typical Install</p>
      </div>
    </div>
  </div>
</section>
