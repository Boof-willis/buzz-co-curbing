---
interface Props {
  phone: string;
  phoneHref: string;
  locationId: string;
}

const { phone, phoneHref, locationId } = Astro.props;
const estimateUrl = `/${locationId}/get-estimate/`;
---

<div
  id="mobile-cta-bar"
  class="fixed -bottom-12 left-0 right-0 z-50 flex items-center justify-between gap-2 bg-dark px-3 pb-[calc(3rem+max(0.75rem,env(safe-area-inset-bottom)))] pt-3 md:hidden translate-y-full transition-transform duration-500 ease-out"
  aria-label="Quick actions"
>
  <a
    href={estimateUrl}
    data-estimate-href
    class="font-heading flex flex-1 items-center justify-center rounded-none bg-[#fcc33c] px-2 py-3 text-sm font-semibold text-dark transition-transform duration-300 hover:scale-[1.02] focus:outline-none focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2 focus-visible:ring-offset-dark whitespace-nowrap"
  >
    Get a Free Estimate
  </a>
  <a
    href={phoneHref}
    data-phone-href
    class="font-data font-heading flex flex-1 items-center justify-center rounded-none border border-white/20 px-2 py-3 text-sm font-semibold text-white transition-all duration-300 hover:bg-white/5 hover:scale-[1.02] focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-dark whitespace-nowrap"
  >
    <span data-phone-display>{phone}</span>
  </a>
</div>

<script>
  const bar = document.getElementById('mobile-cta-bar');
  if (bar) {
    const show = () => {
      if (window.scrollY >= window.innerHeight) {
        bar.classList.remove('translate-y-full');
      } else {
        bar.classList.add('translate-y-full');
      }
    };
    window.addEventListener('scroll', show, { passive: true });
    show();
  }
</script>
