---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="pt-28 pb-4 md:pt-36 md:pb-6">
  <div class="mx-auto max-w-6xl px-6 md:px-8">
    <ol class="flex flex-wrap items-center gap-1.5 font-data text-xs uppercase tracking-wider text-dark/40">
      {items.map((item, i) => (
        <li class="flex items-center gap-1.5">
          {i > 0 && <span aria-hidden="true">/</span>}
          {item.href ? (
            <a href={item.href} class="transition-colors hover:text-accent">{item.label}</a>
          ) : (
            <span class="text-dark/70">{item.label}</span>
          )}
        </li>
      ))}
    </ol>
  </div>
</nav>
