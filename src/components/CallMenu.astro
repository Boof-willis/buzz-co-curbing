---
interface Props {
  variant?: 'hero' | 'mobile-menu' | 'floating-cta';
}

const { variant = 'hero' } = Astro.props;

const branches = [
  { name: 'Cache Valley / Logan', phone: '(435) 557-3648', href: 'tel:+14355573648' },
  { name: 'Brigham City to Sandy', phone: '(385) 365-2121', href: 'tel:+13853652121' },
  { name: 'Draper to Provo', phone: '(385) 533-6525', href: 'tel:+13855336525' },
];

const isFloating = variant === 'floating-cta';
const isMobileMenu = variant === 'mobile-menu';
---

<div class="call-menu relative inline-block" data-call-menu>
  {/* Trigger button */}
  {variant === 'hero' && (
    <button
      type="button"
      data-call-menu-trigger
      class="font-data text-xl font-medium text-white/90 transition-colors hover:text-white cursor-pointer"
    >
      Call Us
      <svg class="inline-block ml-1 h-4 w-4 transition-transform duration-200" data-call-menu-chevron viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M14.77 12.79a.75.75 0 01-1.06-.02L10 8.832l-3.71 3.938a.75.75 0 11-1.08-1.04l4.25-4.5a.75.75 0 011.08 0l4.25 4.5a.75.75 0 01-.02 1.06z" clip-rule="evenodd" />
      </svg>
    </button>
  )}

  {variant === 'floating-cta' && (
    <button
      type="button"
      data-call-menu-trigger
      class="font-heading flex w-full items-center justify-center rounded-none border border-white/20 px-2 py-3 text-sm font-semibold text-white transition-all duration-300 hover:bg-white/5 hover:scale-[1.02] focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-dark whitespace-nowrap cursor-pointer"
    >
      Call Us
      <svg class="ml-1.5 h-3.5 w-3.5 transition-transform duration-200" data-call-menu-chevron viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M14.77 12.79a.75.75 0 01-1.06-.02L10 8.832l-3.71 3.938a.75.75 0 11-1.08-1.04l4.25-4.5a.75.75 0 011.08 0l4.25 4.5a.75.75 0 01-.02 1.06z" clip-rule="evenodd" />
      </svg>
    </button>
  )}

  {variant === 'mobile-menu' && (
    <button
      type="button"
      data-call-menu-trigger
      class="font-data text-xl font-medium text-gold transition-all duration-500 hover:text-gold/80 focus:outline-none cursor-pointer text-left"
    >
      Call Us
      <svg class="inline-block ml-1 h-4 w-4 transition-transform duration-200" data-call-menu-chevron viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
      </svg>
    </button>
  )}

  {/* Dropdown */}
  <div
    data-call-menu-dropdown
    class:list={[
      'absolute z-[80] min-w-[220px] overflow-hidden rounded-sm border shadow-xl opacity-0 pointer-events-none transition-all duration-200 scale-95',
      isFloating ? 'bottom-full mb-2 right-0 bg-dark border-white/10' : '',
      isMobileMenu ? 'top-full mt-2 left-0 bg-dark border-white/10' : '',
      variant === 'hero' ? 'bottom-full mb-2 left-0 bg-dark/95 backdrop-blur-md border-white/10' : '',
    ]}
  >
    {branches.map((branch) => (
      <a
        href={branch.href}
        class:list={[
          'flex flex-col gap-0.5 px-4 py-3 transition-colors',
          'text-white/80 hover:bg-white/10 hover:text-white',
        ]}
      >
        <span class="font-heading text-sm font-semibold">{branch.name}</span>
        <span class="font-data text-xs text-white/50">{branch.phone}</span>
      </a>
    ))}
  </div>
</div>

<script>
  document.querySelectorAll('[data-call-menu]').forEach((menu) => {
    const trigger = menu.querySelector('[data-call-menu-trigger]');
    const dropdown = menu.querySelector('[data-call-menu-dropdown]');
    const chevron = menu.querySelector('[data-call-menu-chevron]');
    if (!trigger || !dropdown) return;

    let open = false;

    function toggle() {
      open = !open;
      dropdown.classList.toggle('opacity-0', !open);
      dropdown.classList.toggle('pointer-events-none', !open);
      dropdown.classList.toggle('scale-95', !open);
      dropdown.classList.toggle('opacity-100', open);
      dropdown.classList.toggle('scale-100', open);
      if (chevron) chevron.style.transform = open ? 'rotate(180deg)' : '';
    }

    trigger.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      toggle();
    });

    document.addEventListener('click', (e) => {
      if (open && !menu.contains(e.target)) {
        toggle();
      }
    });
  });
</script>
