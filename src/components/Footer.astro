---
import locationsData from '../data/locations.json';

interface Props {
  locationId: string;
  phone: string;
  phoneHref: string;
}

const { locationId, phone, phoneHref } = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isRoot = pathname === '/' || pathname === '/about' || pathname === '/gallery' || pathname === '/process' || pathname === '/contact' || pathname === '/privacy' || pathname === '/terms' || pathname.startsWith('/services');
const allLocations = locationsData.locations;
const currentLocation = allLocations.find(l => l.id === locationId) || allLocations[0];

const serviceLinks = [
  { label: "Decorative Curbing", href: "/services/decorative-concrete-curbing/" },
  { label: "Landscape Edging", href: "/services/landscape-edging/" },
  { label: "Stamped Curbing", href: "/services/stamped-concrete-curbing/" },
  { label: "Custom Colors", href: "/services/custom-color-curbing/" },
  { label: "Curbing Repair", href: "/services/curbing-repair/" },
];

const companyLinks = [
  { label: "About", href: "/about/" },
  { label: "Process", href: "/process/" },
  { label: "Gallery", href: "/gallery/" },
  { label: "Service Areas", href: "/#service-areas" },
  { label: "Contact", href: "/contact/" },
];
---

<footer class="mt-20 bg-dark pt-20 pb-28 md:pb-12" aria-label="Site footer">
  <div class="mx-auto max-w-7xl px-6 md:px-8">
    <div class="mb-16 grid gap-12 md:grid-cols-4">
      <!-- Column 1 — Brand -->
      <div>
        <a href="/" aria-label="Buzz Co Curbing — Home">
          <img src="/images/logo-full-dark.svg" alt="Buzz Co Curbing" class="h-12 w-auto mb-4 transition-opacity hover:opacity-80" />
        </a>
        <p class="font-body mt-4 text-sm text-white/50">
          Premium decorative concrete curbing for Utah homeowners.
        </p>
      </div>

      <!-- Column 2 — Services -->
      <div>
        <p class="font-data mb-4 text-xs uppercase tracking-widest text-white/30">SERVICES</p>
        <ul class="space-y-2">
          {serviceLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-white/60 transition-colors hover:text-[#fcc33c]"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3 — Company -->
      <div>
        <p class="font-data mb-4 text-xs uppercase tracking-widest text-white/30">COMPANY</p>
        <ul class="space-y-2">
          {companyLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-white/60 transition-colors hover:text-[#fcc33c]"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4 — Contact -->
      <div>
        <p class="font-data mb-4 text-xs uppercase tracking-widest text-white/30">CONTACT</p>

        {isRoot ? (
          <div class="space-y-5">
            {allLocations.map((loc) => (
              <div>
                <p class="font-data text-[11px] uppercase tracking-widest text-white/40 mb-1">{loc.label}</p>
                <a
                  href={loc.phoneHref}
                  class="font-data font-semibold text-base text-white transition-colors hover:text-[#fcc33c] block"
                >{loc.phone}</a>
                <a
                  href={`mailto:${loc.email}`}
                  class="text-sm text-white/60 transition-colors hover:text-[#fcc33c] block"
                >{loc.email}</a>
              </div>
            ))}
          </div>
        ) : (
          <>
            <p class="font-data">
              <a
                href={currentLocation.phoneHref}
                data-phone-href
                class="font-data font-semibold text-lg text-white transition-colors hover:text-[#fcc33c]"
              >
                <span data-phone-display>{currentLocation.phone}</span>
              </a>
            </p>
            <p class="mt-2">
              <a
                href={`mailto:${currentLocation.email}`}
                class="text-sm text-white/60 transition-colors hover:text-[#fcc33c]"
              >
                {currentLocation.email}
              </a>
            </p>
          </>
        )}

        <p class="font-body mt-3 text-sm text-white/40">Mon–Sat 9AM–5PM</p>
        <div class="mt-4 flex gap-4">
          <a
            href="https://www.facebook.com/profile.php?id=100086676791590&utm_source=website&utm_medium=footer&utm_content=facebook"
            class="text-white/60 transition-colors hover:text-[#fcc33c]"
            aria-label="Facebook"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951" />
            </svg>
          </a>
          <a
            href="https://www.instagram.com/buzzcocurbing/?utm_source=website&utm_medium=footer&utm_content=instagram"
            class="text-white/60 transition-colors hover:text-[#fcc33c]"
            aria-label="Instagram"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 16 16" aria-hidden="true">
              <path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.9 3.9 0 0 0-1.417.923A3.9 3.9 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.9 3.9 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.9 3.9 0 0 0-.923-1.417A3.9 3.9 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599s.453.546.598.92c.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.5 2.5 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.5 2.5 0 0 1-.92-.598 2.5 2.5 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233s.008-2.388.046-3.231c.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92s.546-.453.92-.598c.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92m-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217m0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 md:flex-row">
      <div class="flex flex-wrap items-center justify-center gap-4 font-data text-xs text-white/20">
        <span>© 2026 Buzz Co Curbing. All rights reserved.</span>
        <a href="/privacy/" class="transition-colors hover:text-white/50">Privacy Policy</a>
        <a href="/terms/" class="transition-colors hover:text-white/50">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
