---
interface Props {
  locationId: string;
}

const { locationId } = Astro.props;

// Dot grid pattern as inline SVG data URI (small circles at regular intervals)
const dotGridSvg = [0, 1, 2, 3]
  .flatMap((y) => [0, 1, 2, 3].map((x) => `<circle cx="${4 + x * 8}" cy="${4 + y * 8}" r="1" fill="%23ffffff"/>`))
  .join('');
const dotGridPattern = 'data:image/svg+xml,' + encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32">' + dotGridSvg + '</svg>');
const bgStyle = 'background-image: url(\'' + dotGridPattern + '\'); background-repeat: repeat;';
---

<section class="relative overflow-hidden bg-[#1a1a1a] text-white py-24 md:py-40" aria-label="Our philosophy">
  <!-- Background texture -->
  <div class="absolute inset-0 opacity-10" style={bgStyle} aria-hidden="true"></div>

  <div class="relative z-10 mx-auto max-w-4xl px-6 md:px-8">
    <p class="font-data mb-12 text-xs uppercase tracking-[0.2em] text-white/30" data-philosophy-reveal>
      OUR PHILOSOPHY
    </p>

    <p class="font-body mb-6 max-w-2xl text-lg text-white/50 md:text-xl" data-philosophy-reveal>
      Most curbing companies show up, install a line, and leave. They don't walk the yard with you. They don't ask about your vision.
    </p>

    <p class="font-heading font-bold mb-8 text-3xl leading-tight text-white md:text-5xl lg:text-6xl" data-philosophy-reveal>
      We design it <span class="text-gold">with you</span>, on your property, before any work begins.
    </p>

    <p class="font-body max-w-2xl text-base text-white/60 md:text-lg" data-philosophy-reveal>
      Our crew walks every job with you before work begins. No surprises, no cookie-cutter layouts. Your curbing should look like it was designed for your yard — because it was.
    </p>

    <div class="mt-12" data-philosophy-reveal>
      <a href="/gallery/" class="btn-primary">
        See Our Work →
      </a>
    </div>
  </div>
</section>
