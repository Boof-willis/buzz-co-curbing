---
interface Testimonial {
  name: string;
  city: string;
  rating: number;
  text: string;
  placeholder?: boolean;
}

interface Props {
  testimonials: Testimonial[];
  locationId: string;
}

const { testimonials, locationId } = Astro.props;

const starPath =
  "M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z";
---

<section class="bg-warm-gray py-20 md:py-32" aria-label="Client testimonials">
  <div class="mx-auto max-w-7xl px-6 md:px-8">
    <p class="section-label mb-4">CLIENT VOICES</p>
    <h2 class="font-heading text-section-heading font-bold text-dark mb-4">
      Don't Just Take Our Word For It
    </h2>

    <!-- Google rating badge -->
    <div class="mb-12 inline-flex items-center gap-2 rounded-none border border-dark/[0.06] bg-white px-4 py-2 shadow-sm">
      <svg class="h-4 w-4 shrink-0 text-[#fcc33c]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d={starPath} />
      </svg>
      <svg class="h-4 w-4 shrink-0 text-[#fcc33c]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d={starPath} />
      </svg>
      <svg class="h-4 w-4 shrink-0 text-[#fcc33c]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d={starPath} />
      </svg>
      <svg class="h-4 w-4 shrink-0 text-[#fcc33c]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d={starPath} />
      </svg>
      <svg class="h-4 w-4 shrink-0 text-[#fcc33c]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d={starPath} />
      </svg>
      <span class="font-data text-sm text-dark">4.9 on Google</span>
    </div>

    <!-- Testimonial grid (masonry via CSS columns) -->
    <div class="columns-1 gap-6 space-y-6 md:columns-2 lg:columns-3">
      {testimonials.map((t, i) => (
        <article
          class={`break-inside-avoid rounded-none border border-dark/[0.08] bg-white p-8 md:p-10 shadow-sm shadow-dark/[0.05] ${i >= 4 ? 'hidden md:block' : ''}`}
        >
          {t.placeholder && (
            <>
              <!-- PLACEHOLDER: Replace with real testimonial from this territory -->
            </>
          )}
          <p class="font-drama mb-4 text-5xl leading-none text-[#fcc33c] opacity-20" aria-hidden="true">"</p>
          <p class="font-body mb-6 text-base leading-relaxed text-dark/80">{t.text}</p>
          <footer class="flex flex-col gap-2">
            <div class="flex shrink-0 gap-0.5">
              <svg class="h-4 w-4 shrink-0 text-[#fcc33c]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d={starPath} />
              </svg>
              <svg class="h-4 w-4 shrink-0 text-[#fcc33c]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d={starPath} />
              </svg>
              <svg class="h-4 w-4 shrink-0 text-[#fcc33c]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d={starPath} />
              </svg>
              <svg class="h-4 w-4 shrink-0 text-[#fcc33c]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d={starPath} />
              </svg>
              <svg class="h-4 w-4 shrink-0 text-[#fcc33c]" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d={starPath} />
              </svg>
            </div>
            <div>
              <span class="font-heading text-sm font-semibold text-dark">{t.name}</span>
              <span class="font-data ml-2 text-xs text-warm-muted">{t.city}</span>
            </div>
          </footer>
        </article>
      ))}
    </div>

    <!-- Secondary CTA -->
    <div class="mt-16 text-center">
      <p class="font-body mb-4 text-dark/70">Not sure which service you need?</p>
      <a href="/services/" class="btn-secondary">
        Explore Our Services →
      </a>
    </div>
  </div>
</section>
