const { citySlug } = Astro.props;
const city = cityContent[citySlug];
const neighboringCities = loc.priorityCities.filter(c => c !== city.name);

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: `Buzz Co Curbing — ${city.name}`,
  description: city.description,
  url: `https://www.buzzcocurb.com/central/areas/${citySlug}/`,
  telephone: loc.phone,
  email: loc.email,
  areaServed: {
    '@type': 'City',
    name: city.name,
    containedInPlace: { '@type': 'State', name: 'Utah' },
  },
  openingHoursSpecification: loc.hoursSpec.map(h => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: h.dayOfWeek,
    opens: h.opens,
    closes: h.closes,
  })),
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '50',
    bestRating: '5',
  },
};

const breadcrumbSchema = {
