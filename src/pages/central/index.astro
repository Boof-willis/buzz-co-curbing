---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import TrustBar from '../../components/TrustBar.astro';
import Features from '../../components/Features.astro';
import SocialProof from '../../components/SocialProof.astro';
import CounterStats from '../../components/CounterStats.astro';
import CounterStatsAnimation from '../../components/CounterStatsAnimation.jsx';
import Philosophy from '../../components/Philosophy.astro';
import PhilosophyReveal from '../../components/PhilosophyReveal.jsx';
import Protocol from '../../components/Protocol.astro';
import FAQ from '../../components/FAQ.astro';
import GetStarted from '../../components/GetStarted.astro';
import CrossTerritoryLink from '../../components/CrossTerritoryLink.astro';
import locationsData from '../../data/locations.json';

const loc = locationsData.locations.find(l => l.id === 'central');

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: 'Buzz Co Curbing — Central',
  description: loc.tagline,
  url: 'https://www.buzzcocurb.com/central/',
  telephone: loc.phone,
  email: loc.email,
  address: {
    '@type': 'PostalAddress',
    addressRegion: 'UT',
    addressCountry: 'US',
  },
  areaServed: [
    {"@type": "City", "name": "Brigham City"},
    {"@type": "City", "name": "Ogden"},
    {"@type": "City", "name": "Layton"},
    {"@type": "City", "name": "Bountiful"},
    {"@type": "City", "name": "Salt Lake City"},
    {"@type": "City", "name": "West Valley City"},
    {"@type": "City", "name": "West Jordan"},
    {"@type": "City", "name": "Murray"},
    {"@type": "City", "name": "Taylorsville"},
    {"@type": "City", "name": "Sandy"},
    {"@type": "City", "name": "South Jordan"},
    {"@type": "City", "name": "Cottonwood Heights"},
    {"@type": "City", "name": "Millcreek"},
    {"@type": "City", "name": "Holladay"},
    {"@type": "City", "name": "Kearns"},
    {"@type": "City", "name": "Magna"},
    {"@type": "City", "name": "South Salt Lake"},
    {"@type": "City", "name": "Kaysville"},
    {"@type": "City", "name": "Farmington"},
    {"@type": "City", "name": "Centerville"},
    {"@type": "City", "name": "Roy"},
    {"@type": "City", "name": "Clearfield"},
    {"@type": "City", "name": "North Ogden"},
    {"@type": "City", "name": "South Ogden"},
  ],
  openingHoursSpecification: loc.hoursSpec.map(h => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: h.dayOfWeek,
    opens: h.opens,
    closes: h.closes,
  })),
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '50',
    bestRating: '5',
  },
};
---

<BaseLayout
  title="Concrete Curbing — Brigham City to Sandy | Buzz Co Curbing"
  description="Premium decorative concrete curbing from Brigham City to Sandy. 14 colors, 10 patterns. Free estimates from Buzz Co Curbing."
  canonical="https://www.buzzcocurb.com/central/"
  geoPlacename="Salt Lake City"
  geoRegion="US-UT"
  locationId={loc.id}
  phone={loc.phone}
  phoneHref={loc.phoneHref}

  schema={localBusinessSchema}
  showFaq={true}
>
  <Hero
    locationId={loc.id}
    locationName={loc.name}
    cityName="Salt Lake City"
    headline="Crafted Concrete Curbing From Brigham City to Sandy"
    phone={loc.phone}
    phoneHref={loc.phoneHref}
    estimateUrl={`/${loc.id}/get-estimate/`}
  />
  <TrustBar />
  <Features locationId={loc.id} cityName="Salt Lake City" />
  <SocialProof testimonials={loc.testimonials} locationId={loc.id} />
  <CounterStats />
  <CounterStatsAnimation client:visible />
  <Philosophy locationId={loc.id} />
  <PhilosophyReveal client:visible />
  <Protocol />
  <FAQ locationId={loc.id} cityName="Salt Lake City" />
  <GetStarted
    locationId={loc.id}
    phone={loc.phone}
    phoneHref={loc.phoneHref}
    testimonial={loc.testimonials[0] ? { name: loc.testimonials[0].name, text: loc.testimonials[0].text, rating: loc.testimonials[0].rating } : undefined}
  />
  <CrossTerritoryLink locationId={loc.id} />
</BaseLayout>
