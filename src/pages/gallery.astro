---
import BaseLayout from '../layouts/BaseLayout.astro';

const galleryImages = [
  { src: '/images/gallery/stone-home-decorative-curbing-mulch-bed-utah.jpg', alt: 'Decorative concrete curbing bordering mulch beds at a stone exterior home in Utah' },
  { src: '/images/gallery/winding-concrete-curbing-lawn-border-utah.jpg', alt: 'Winding S-curve concrete curbing separating lawn from mulch beds with lake views in Utah' },
  { src: '/images/gallery/curbing-mulch-bed-boulder-utah-lake-view.jpg', alt: 'Concrete landscape curbing around mulch bed with boulders and Utah lake view' },
  { src: '/images/gallery/landscape-curbing-driveway-edge-utah-lake-view.jpg', alt: 'Concrete curbing along driveway edge with young tree and lake view in Utah' },
  { src: '/images/gallery/hexagonal-paver-walkway-charcoal-utah.jpg', alt: 'Charcoal hexagonal concrete paver walkway with white rock border in Utah backyard' },
  { src: '/images/gallery/dark-paver-pathway-hexagon-pattern-utah.jpg', alt: 'Dark hexagonal paver pathway with decorative border edging in Utah' },
  { src: '/images/gallery/backyard-curbing-black-rock-mulch-aerial-utah.jpg', alt: 'Aerial view of backyard concrete curbing bordering black rock mulch beds in Utah' },
  { src: '/images/gallery/paver-patio-curbing-backyard-aerial-utah.jpg', alt: 'Aerial view of cobblestone paver patio with concrete curbing and rock mulch in Utah backyard' },
  { src: '/images/gallery/concrete-stepping-stones-gravel-pathway-utah.jpg', alt: 'Concrete stepping stone pathway set in decorative gravel with landscape curbing in Utah' },
  { src: '/images/gallery/concrete-curbing-stamped-cache-valley-03.jpg', alt: 'Stamped and colored concrete curbing in Cache Valley, Utah' },
  { src: '/images/gallery/block-curbing-rock-garden-logan-04.avif', alt: 'Curved concrete landscape curbing surrounding a rock garden in a Logan, Utah backyard' },
  { src: '/images/gallery/stamped-curbing-mulch-bed-providence-06.avif', alt: 'Curved stamped concrete curbing separating lawn from mulched garden bed in Providence, Utah' },
  { src: '/images/gallery/concrete-curbing-benson-utah-11.jpg', alt: 'Concrete landscape curbing installed at a home in Benson, Utah' },
  { src: '/images/gallery/stained-curbing-cache-county-12.jpg', alt: 'Stained concrete curbing services completed in Cache County, Utah' },
  { src: '/images/gallery/stained-stamped-curbing-logan-15.jpg', alt: 'Stained and stamped decorative concrete curbing in Logan, Utah' },
  { src: '/images/gallery/stamped-stained-curbing-hyrum-16.jpg', alt: 'Stamped and stained concrete curbing contracting services in Hyrum, Utah' },
];
---

<BaseLayout
  title="Curbing Photo Gallery | Buzz Co Curbing"
  description="Browse completed concrete curbing projects across Utah. See stamped patterns, custom colors, and mower-style edges on real homes."
>
  <section class="pt-32 pb-20 md:pt-40 md:pb-32 bg-warm-white">
    <div class="max-w-6xl mx-auto px-6 md:px-8">
      <p class="section-label mb-4">OUR WORK</p>
      <h1 class="font-heading text-section-heading font-bold text-dark mb-6">Curbing Projects Across Utah</h1>
      <p class="font-body text-lg text-dark/60 max-w-2xl mb-12">
        Every yard tells a different story. Browse our completed projects to see the range of styles, colors, and patterns we install for Utah homeowners.
      </p>

      <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
        {galleryImages.map((img) => (
          <div class="break-inside-avoid overflow-hidden group">
            <img
              src={img.src}
              alt={img.alt}
              loading="lazy"
              decoding="async"
              class="w-full h-auto block transition-transform duration-500 group-hover:scale-[1.03]"
            />
          </div>
        ))}
      </div>

      <div class="text-center mt-16">
        <p class="font-body text-dark/60 mb-4">Want to see your yard transformed next?</p>
        <a href="/logan/get-estimate/" class="btn-primary">
          <span class="btn-bg" aria-hidden="true"></span>
          <span class="btn-text">Get a Free Estimate</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
