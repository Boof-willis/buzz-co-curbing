---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import TrustBar from '../../components/TrustBar.astro';
import Features from '../../components/Features.astro';
import SocialProof from '../../components/SocialProof.astro';
import CounterStats from '../../components/CounterStats.astro';
import CounterStatsAnimation from '../../components/CounterStatsAnimation.jsx';
import Philosophy from '../../components/Philosophy.astro';
import PhilosophyReveal from '../../components/PhilosophyReveal.jsx';
import Protocol from '../../components/Protocol.astro';
import FAQ from '../../components/FAQ.astro';
import GetStarted from '../../components/GetStarted.astro';
import CrossTerritoryLink from '../../components/CrossTerritoryLink.astro';
import locationsData from '../../data/locations.json';

const loc = locationsData.locations.find(l => l.id === 'south');

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: 'Buzz Co Curbing — South',
  description: loc.tagline,
  url: 'https://www.buzzcocurb.com/south/',
  telephone: loc.phone,
  email: loc.email,
  address: {
    '@type': 'PostalAddress',
    addressRegion: 'UT',
    addressCountry: 'US',
  },
  areaServed: [
    {"@type": "City", "name": "Draper"},
    {"@type": "City", "name": "Riverton"},
    {"@type": "City", "name": "Lehi"},
    {"@type": "City", "name": "American Fork"},
    {"@type": "City", "name": "Pleasant Grove"},
    {"@type": "City", "name": "Orem"},
    {"@type": "City", "name": "Provo"},
    {"@type": "City", "name": "Eagle Mountain"},
    {"@type": "City", "name": "Saratoga Springs"},
    {"@type": "City", "name": "Alpine"},
    {"@type": "City", "name": "Highland"},
    {"@type": "City", "name": "Cedar Hills"},
    {"@type": "City", "name": "Lindon"},
    {"@type": "City", "name": "Vineyard"},
    {"@type": "City", "name": "Springville"},
    {"@type": "City", "name": "Mapleton"},
    {"@type": "City", "name": "Spanish Fork"},
    {"@type": "City", "name": "Salem"},
  ],
  openingHoursSpecification: loc.hoursSpec.map(h => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: h.dayOfWeek,
    opens: h.opens,
    closes: h.closes,
  })),
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '50',
    bestRating: '5',
  },
};
---

<BaseLayout
  title="Concrete Curbing — Draper to Provo | Buzz Co Curbing"
  description="Premium decorative concrete curbing from Draper to Provo. 14 colors, 10 patterns, same-week scheduling. Free estimates from Buzz Co Curbing."
  canonical="https://www.buzzcocurb.com/south/"
  geoPlacename="Lehi"
  geoRegion="US-UT"
  locationId={loc.id}
  phone={loc.phone}
  phoneHref={loc.phoneHref}

  schema={localBusinessSchema}
  showFaq={true}
>
  <Hero
    locationId={loc.id}
    locationName={loc.name}
    cityName="Lehi"
    headline="Crafted Concrete Curbing From Draper to Provo"
    phone={loc.phone}
    phoneHref={loc.phoneHref}
    estimateUrl={`/${loc.id}/get-estimate/`}
  />
  <TrustBar />
  <Features locationId={loc.id} cityName="Lehi" />
  <SocialProof testimonials={loc.testimonials} locationId={loc.id} />
  <CounterStats />
  <CounterStatsAnimation client:visible />
  <Philosophy locationId={loc.id} />
  <PhilosophyReveal client:visible />
  <Protocol />
  <FAQ locationId={loc.id} cityName="Lehi" />
  <GetStarted
    locationId={loc.id}
    phone={loc.phone}
    phoneHref={loc.phoneHref}
    testimonial={loc.testimonials[0] ? { name: loc.testimonials[0].name, text: loc.testimonials[0].text, rating: loc.testimonials[0].rating } : undefined}
  />
  <CrossTerritoryLink locationId={loc.id} />
</BaseLayout>
